</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
/* ══════════════════════════════════
   INIT
══════════════════════════════════ */
document.getElementById('footerYear').textContent = new Date().getFullYear();

/* ══════════════════════════════════
   COOKIE
══════════════════════════════════ */
(function() {
  if (localStorage.getItem('cookie_consent')) {
    document.getElementById('cookieBanner').classList.add('gone');
  }
  document.getElementById('cookieAccept').addEventListener('click', function() {
    localStorage.setItem('cookie_consent', 'accepted');
    document.getElementById('cookieBanner').classList.add('gone');
  });
  document.getElementById('cookieDecline').addEventListener('click', function() {
    localStorage.setItem('cookie_consent', 'declined');
    document.getElementById('cookieBanner').classList.add('gone');
  });
})();

/* ══════════════════════════════════
   UTILS
══════════════════════════════════ */
function esc(str) {
  return String(str).replace(/[&<>"']/g, m => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));
}
function getToken() { return localStorage.getItem('fpv_token') || ''; }
function setToken(t) { if (t) localStorage.setItem('fpv_token', t); else localStorage.removeItem('fpv_token'); }

/* ══════════════════════════════════
   TAB NAVIGATION
══════════════════════════════════ */
function setTab(name) {
  document.querySelectorAll('[data-tab-content]').forEach(el =>
    el.classList.toggle('active', el.getAttribute('data-tab-content') === name)
  );
  document.querySelectorAll('[data-tabbtn]').forEach(btn =>
    btn.classList.toggle('active', btn.getAttribute('data-tabbtn') === name)
  );
  document.querySelectorAll('[data-bn]').forEach(btn =>
    btn.classList.toggle('active', btn.getAttribute('data-bn') === name)
  );
  closeDrawers();
  if (name === 'search') setTimeout(() => map && map.invalidateSize(), 80);
}
document.querySelectorAll('[data-tabbtn]').forEach(btn =>
  btn.addEventListener('click', () => setTab(btn.getAttribute('data-tabbtn')))
);
document.querySelectorAll('[data-bn]').forEach(btn =>
  btn.addEventListener('click', () => setTab(btn.getAttribute('data-bn')))
);

/* ══════════════════════════════════
   DRAWERS
══════════════════════════════════ */
function closeDrawers() {
  document.body.classList.remove('show-left', 'show-right');
}
function toggleDrawer(side) {
  const cls = side === 'left' ? 'show-left' : 'show-right';
  const other = side === 'left' ? 'show-right' : 'show-left';
  if (document.body.classList.contains(cls)) closeDrawers();
  else { document.body.classList.remove(other); document.body.classList.add(cls); }
}
document.getElementById('toggleLeft').addEventListener('click', () => toggleDrawer('left'));
document.getElementById('toggleRight').addEventListener('click', () => toggleDrawer('right'));
document.getElementById('drawerOverlay').addEventListener('click', closeDrawers);

/* ══════════════════════════════════
   CREDITS UI
══════════════════════════════════ */
let _totalCredits = 5; // default for progress calc

function updateCreditsUI(credits, resetAt) {
  const bar = document.getElementById('creditsBar');
  const countEl = document.getElementById('creditCount');
  const labelEl = document.getElementById('creditLabel');
  const resetEl = document.getElementById('creditReset');
  const fillEl = document.getElementById('creditFill');
  if (!bar) return;

  if (credits !== undefined && credits !== null) {
    bar.classList.add('visible');
    bar.classList.toggle('empty', credits <= 0);
    countEl.textContent = credits;
    labelEl.textContent = 'crédit' + (credits !== 1 ? 's' : '') + ' restant' + (credits !== 1 ? 's' : '');
    if (resetAt) {
      const d = new Date(resetAt);
      resetEl.textContent = 'Renouvellement le ' + d.toLocaleDateString('fr-CA', { day: 'numeric', month: 'long' });
    }
    const pct = Math.min(100, Math.max(0, (credits / Math.max(_totalCredits, 5)) * 100));
    fillEl.style.width = pct + '%';
    fillEl.style.background = credits <= 0 ? 'var(--red)' : credits <= 1 ? '#f97316' : 'var(--accent)';
  } else {
    bar.classList.remove('visible');
  }
}

/* ══════════════════════════════════
   AUTH STATUS
══════════════════════════════════ */
function setAuthUI(html, online = false) {
  const el = document.getElementById('authStatus');
  const dot = document.getElementById('statusDot');
  const pill = document.getElementById('authPill');
  const text = String(html).replace(/<[^>]+>/g, '');
  el.innerHTML = '<div class="status-dot' + (online ? ' online' : '') + '"></div><span>' + html + '</span>';
  pill.textContent = text.slice(0, 80) || 'Non connecté';
}

async function refreshMe() {
  const token = getToken();
  const adminPanel = document.getElementById('adminPanel');
  if (!token) {
    setAuthUI('Non connecté', false);
    adminPanel.style.display = 'none';
    updateCreditsUI(null);
    return;
  }
  const res = await fetch('/me', { headers: { Authorization: 'Bearer ' + token } });
  const data = await res.json().catch(() => ({}));
  if (!res.ok || data.error) {
    setToken('');
    setAuthUI('Non connecté', false);
    adminPanel.style.display = 'none';
    updateCreditsUI(null);
    return;
  }
  const u = data.user || {};
  setAuthUI('<strong>' + esc(u.displayName || u.email || 'Utilisateur') + '</strong><br><span style="font-size:11px;color:var(--text3)">' + esc(u.email || '') + '</span>', true);
  adminPanel.style.display = (u.role === 'admin') ? 'block' : 'none';
  if (data.credits !== undefined) {
    _totalCredits = Math.max(5, data.credits);
    updateCreditsUI(data.credits, data.credits_reset_at);
  }
}

/* ══════════════════════════════════
   AUTH ACTIONS
══════════════════════════════════ */
async function register() {
  const email = document.getElementById('authEmail').value.trim();
  const password = document.getElementById('authPass').value;
  const displayName = document.getElementById('authName').value.trim();
  setAuthUI('Création du compte…');
  const res = await fetch('/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, password, displayName }) });
  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  if (!res.ok || data.error) { setAuthUI('<span style="color:var(--red)">' + esc(data.error || 'Erreur') + '</span>'); return; }
  setToken(data.token || '');
  if (data.credits !== undefined) updateCreditsUI(data.credits);
  await refreshMe();
  await loadRegions();
  loadTopSpots();
}

async function login() {
  const email = document.getElementById('authEmail').value.trim();
  const password = document.getElementById('authPass').value;
  setAuthUI('Connexion…');
  const res = await fetch('/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, password }) });
  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  if (!res.ok || data.error) { setAuthUI('<span style="color:var(--red)">' + esc(data.error || 'Erreur') + '</span>'); return; }
  setToken(data.token || '');
  if (data.credits !== undefined) updateCreditsUI(data.credits, data.credits_reset_at);
  await refreshMe();
  await loadRegions();
  loadTopSpots();
}

async function logout() {
  const token = getToken();
  if (token) await fetch('/logout', { method: 'POST', headers: { Authorization: 'Bearer ' + token } }).catch(() => {});
  setToken('');
  await refreshMe();
  loadTopSpots();
}

async function changePassword() {
  const t = getToken();
  if (!t) { setAuthUI('<span style="color:var(--red)">Connecte-toi d\'abord</span>'); return; }
  const oldPass = prompt('Ancien mot de passe :');
  if (!oldPass) return;
  const newPass = prompt('Nouveau mot de passe (min. 8 caractères) :');
  if (!newPass) return;
  if (newPass.length < 8) { setAuthUI('<span style="color:var(--red)">Mot de passe trop court</span>'); return; }
  setAuthUI('Modification en cours…');
  const res = await fetch('/change-password', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t }, body: JSON.stringify({ oldPassword: oldPass, newPassword: newPass }) });
  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  if (!res.ok || data.error) { setAuthUI('<span style="color:var(--red)">' + esc(data.error || 'Erreur') + '</span>'); return; }
  setAuthUI('<span style="color:var(--green)">✓ Mot de passe modifié</span>', true);
}

/* ══════════════════════════════════
   ADMIN
══════════════════════════════════ */
async function adminHide() {
  const t = getToken();
  const spotId = document.getElementById('adminSpotId').value.trim();
  const reason = document.getElementById('adminReason').value.trim();
  const msg = document.getElementById('adminMsg');
  msg.innerHTML = 'Traitement…';
  const res = await fetch('/admin/hide-spot', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t }, body: JSON.stringify({ spotId, reason }) });
  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  msg.innerHTML = (!res.ok || data.error) ? '<span style="color:var(--red)">' + esc(data.error || 'Erreur') + '</span>' : '<span style="color:var(--green)">✓ Spot masqué</span>';
  loadTopSpots();
}

async function adminUnhide() {
  const t = getToken();
  const spotId = document.getElementById('adminSpotId').value.trim();
  const msg = document.getElementById('adminMsg');
  msg.innerHTML = 'Traitement…';
  const res = await fetch('/admin/unhide-spot', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t }, body: JSON.stringify({ spotId }) });
  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  msg.innerHTML = (!res.ok || data.error) ? '<span style="color:var(--red)">' + esc(data.error || 'Erreur') + '</span>' : '<span style="color:var(--green)">✓ Spot réactivé</span>';
  loadTopSpots();
}

async function adminResetPassword() {
  const t = getToken();
  const email = document.getElementById('adminResetEmail').value.trim();
  const newPass = document.getElementById('adminResetPass').value;
  const msg = document.getElementById('adminResetMsg');
  if (!email) { msg.innerHTML = '<span style="color:var(--red)">Email requis</span>'; return; }
  if (!newPass || newPass.length < 8) { msg.innerHTML = '<span style="color:var(--red)">Mot de passe trop court</span>'; return; }
  msg.innerHTML = 'Réinitialisation…';
  const res = await fetch('/admin/reset-password', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t }, body: JSON.stringify({ email, newPassword: newPass }) });
  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  if (!res.ok || data.error) { msg.innerHTML = '<span style="color:var(--red)">' + esc(data.error || 'Erreur') + '</span>'; return; }
  msg.innerHTML = '<span style="color:var(--green)">✓ ' + esc(data.message || 'Réinitialisé') + '</span>';
  document.getElementById('adminResetEmail').value = '';
  document.getElementById('adminResetPass').value = '';
}

/* ══════════════════════════════════
   MAP
══════════════════════════════════ */
let map;
let mapMarkers = [];

function initMap(lat = 45.4, lon = -71.9, zoom = 10) {
  if (!map) {
    map = L.map('map', { zoomControl: true }).setView([lat, lon], zoom);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a>',
      maxZoom: 19,
    }).addTo(map);
  } else {
    map.setView([lat, lon], zoom);
  }
  setTimeout(() => map.invalidateSize(), 120);
}

function clearMapMarkers() {
  if (!map) return;
  mapMarkers.forEach(m => map.removeLayer(m));
  mapMarkers = [];
}

function makeOrangeIcon() {
  return L.divIcon({
    className: '',
    html: '<div style="width:16px;height:16px;background:#e8611a;border:3px solid #fff;border-radius:50%;box-shadow:0 2px 10px rgba(0,0,0,.5);cursor:pointer;transition:transform .15s" onmouseover="this.style.transform=\'scale(1.3)\'" onmouseout="this.style.transform=\'scale(1)\'"></div>',
    iconSize: [16, 16],
    iconAnchor: [8, 8],
  });
}

function showSpotsOnMap(spots) {
  if (!map) initMap();
  clearMapMarkers();
  (spots || []).forEach(s => {
    const m = L.marker([s.lat, s.lon], { icon: makeOrangeIcon() }).addTo(map);
    m.bindPopup(
      '<div style="font-family:DM Sans,system-ui;min-width:180px">' +
      '<b style="font-size:14px;font-family:Syne,sans-serif">' + esc(s.name || 'Spot') + '</b>' +
      '<br><span style="font-family:monospace;font-size:11px;opacity:.6">' + Number(s.lat).toFixed(5) + ', ' + Number(s.lon).toFixed(5) + '</span>' +
      (s.desc ? '<br><div style="font-size:12px;opacity:.7;margin-top:4px;max-width:220px;white-space:normal">' + esc(s.desc.slice(0, 100)) + '</div>' : '') +
      '<br><a href="https://www.google.com/maps/search/?api=1&query=' + s.lat + ',' + s.lon + '" target="_blank" rel="noopener" style="color:#e8611a;font-size:12px;font-weight:700;margin-top:6px;display:inline-block">🗺 Google Maps →</a>' +
      '</div>'
    );
    mapMarkers.push(m);
  });
  if (mapMarkers.length) {
    const g = L.featureGroup(mapMarkers);
    map.fitBounds(g.getBounds().pad(0.2));
  }
}

/* ══════════════════════════════════
   TOAST
══════════════════════════════════ */
function showToast(msg, type = 'info') {
  const el = document.getElementById('resultToast');
  el.className = 'result-toast visible ' + type;
  el.innerHTML = msg;
}
function hideToast() {
  const el = document.getElementById('resultToast');
  el.classList.remove('visible');
}

/* ══════════════════════════════════
   SEARCH
══════════════════════════════════ */
async function send() {
  const email = document.getElementById('email').value.trim();
  const city = document.getElementById('city').value.trim();
  const country = document.getElementById('country').value.trim();
  const radiusKm = document.getElementById('radiusKm').value;
  const btn = document.getElementById('searchBtn');

  if (!email || !city || !country) {
    showToast('⚠ Renseigne email, ville et pays pour lancer la recherche.', 'error');
    return;
  }

  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Recherche en cours…';
  showToast('<div class="spinner"></div> Interrogation d\'Overpass API…', 'info');

  const res = await fetch('/generate', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, city, country, radiusKm, includeWeb: true, webMax: 6 }),
  });

  btn.disabled = false;
  btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="7"/><path d="m16 16 5 5"/></svg> Rechercher les spots';

  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));

  if (!res.ok || data.error) {
    const errMsg = data.error || 'Erreur';
    const extra = data.message ? '<br><small style="opacity:.7">' + esc(data.message) + '</small>' : '';
    if (res.status === 402) {
      showToast('💳 Plus de crédits disponibles.' + extra + '<br><a href="/premium" class="result-link" target="_blank">Acheter des crédits →</a>', 'error');
    } else {
      showToast('❌ ' + esc(errMsg) + extra, 'error');
    }
    return;
  }

  // Update credits
  if (data.credits_remaining !== undefined) {
    updateCreditsUI(data.credits_remaining, data.credits_reset_at);
  }

  const count = Number(data.spots_found || 0);
  const linkHtml = data.url ? ' · <a href="' + data.url + '" target="_blank" rel="noopener" class="result-link">Ouvrir la page complète →</a>' : '';
  showToast('✓ <strong>' + count + ' spot' + (count !== 1 ? 's' : '') + ' trouvé' + (count !== 1 ? 's' : '') + '</strong> autour de <em>' + esc(city) + '</em>' + linkHtml, 'success');

  if (data.spots && data.spots.length) {
    showSpotsOnMap(data.spots);
  } else {
    initMap();
    showToast('ℹ Aucun spot trouvé dans ce rayon. Essaie d\'augmenter le rayon de recherche.', 'info');
  }
}

/* ══════════════════════════════════
   SUBMIT SPOT
══════════════════════════════════ */
async function submitSpot() {
  const name = document.getElementById('spotName').value.trim();
  const lat = parseFloat(document.getElementById('spotLat').value);
  const lon = parseFloat(document.getElementById('spotLon').value);
  const desc = document.getElementById('spotDesc').value;
  const email = document.getElementById('spotEmail').value;
  const type = document.getElementById('spotType').value;
  const access = document.getElementById('spotAccess').value;
  const dangerLevel = parseInt(document.getElementById('spotDanger').value || '1', 10);
  const ownerName = document.getElementById('spotOwnerName').value;
  const region = document.getElementById('spotRegion').value;
  const country = document.getElementById('spotCountry').value;
  const resultEl = document.getElementById('spotResult');

  if (!name || isNaN(lat) || isNaN(lon)) {
    resultEl.innerHTML = '<span style="color:var(--red)">⚠ Nom, latitude et longitude sont requis</span>';
    return;
  }

  resultEl.innerHTML = '<div style="display:flex;align-items:center;gap:8px"><div class="spinner"></div> Envoi en cours…</div>';

  const res = await fetch('/submit-spot', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name, lat, lon, desc, email, type, access, dangerLevel, ownerName, region, country }),
  });

  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  if (!res.ok || data.error) {
    resultEl.innerHTML = '<span style="color:var(--red)">❌ ' + esc(data.error || 'Erreur') + '</span>';
    return;
  }

  resultEl.innerHTML = '<span style="color:var(--green)">✓ Spot partagé avec succès !</span> <a href="/spot/' + data.id + '" target="_blank" rel="noopener" style="font-weight:700">Voir la page →</a>';
  await loadRegions();
  loadTopSpots();
  setTimeout(() => setTab('top'), 800);
}

/* ══════════════════════════════════
   VOTE
══════════════════════════════════ */
async function voteSpot(spotId, stars) {
  const t = getToken();
  if (!t) { alert('Connecte-toi pour voter.'); return; }
  const res = await fetch('/vote-spot', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t },
    body: JSON.stringify({ spotId, stars }),
  });
  const data = await res.json().catch(() => ({ error: 'Réponse invalide' }));
  if (!res.ok || data.error) { alert(data.error || 'Erreur vote'); return; }
  loadTopSpots();
}

/* ══════════════════════════════════
   REGIONS
══════════════════════════════════ */
async function loadRegions() {
  const rSel = document.getElementById('filterRegion');
  const cSel = document.getElementById('filterCountry');
  const res = await fetch('/regions');
  const data = await res.json().catch(() => ({ regions: [], countries: [] }));
  if (!res.ok) return;
  const curR = rSel.value, curC = cSel.value;
  rSel.innerHTML = '<option value="">Toutes les régions</option>' + (data.regions || []).map(r => '<option>' + esc(r) + '</option>').join('');
  cSel.innerHTML = '<option value="">Tous les pays</option>' + (data.countries || []).map(c => '<option>' + esc(c) + '</option>').join('');
  rSel.value = curR;
  cSel.value = curC;
}

/* ══════════════════════════════════
   TOP SPOTS
══════════════════════════════════ */
function dangerBar(level) {
  const l = Math.max(1, Math.min(5, Number(level || 1)));
  const colors = ['#22c55e', '#84cc16', '#f59e0b', '#f97316', '#ef4444'];
  let html = '<div class="danger-bar">';
  for (let i = 1; i <= 5; i++) {
    html += '<div class="danger-dot" style="background:' + (i <= l ? colors[l - 1] : 'rgba(255,255,255,.08)') + '"></div>';
  }
  return html + '</div>';
}

async function loadTopSpots() {
  const topDiv = document.getElementById('topSpots');
  topDiv.innerHTML = '<div style="color:var(--text2);grid-column:1/-1;padding:16px 0;display:flex;align-items:center;gap:10px"><div class="spinner"></div> Chargement…</div>';

  const region = (document.getElementById('filterRegion').value || '').trim();
  const country = (document.getElementById('filterCountry').value || '').trim();
  const qs = new URLSearchParams();
  if (region) qs.set('region', region);
  if (country) qs.set('country', country);

  const res = await fetch('/top-spots' + (qs.toString() ? ('?' + qs.toString()) : ''));
  const data = await res.json().catch(() => ({ spots: [] }));

  if (!res.ok) { topDiv.innerHTML = '<div style="color:var(--red);grid-column:1/-1">Impossible de charger les spots.</div>'; return; }
  if (!data.spots || !data.spots.length) {
    topDiv.innerHTML = '<div style="color:var(--text2);grid-column:1/-1;padding:20px 0;text-align:center">Aucun spot partagé pour le moment.<br><span style="font-size:13px;opacity:.6">Sois le premier à partager un spot !</span></div>';
    return;
  }

  const canVote = !!getToken();
  topDiv.innerHTML = data.spots.map(s => {
    const score = Number(s.score || 0);
    const votes = Number(s.votes || 0);
    const spotId = String(s.id || '');
    const maps = 'https://www.google.com/maps/search/?api=1&query=' + s.lat + ',' + s.lon;
    const badgeHtml = (s.badges || []).map(b => '<span class="badge-pill' + (b === 'NOUVEAU' ? ' new' : b === 'CONFIRMÉ' ? ' confirmed' : '') + '">' + esc(b) + '</span>').join('');

    const voteHtml = canVote
      ? '<div class="vote-stars">' + [1,2,3,4,5].map(n => '<button class="vote-star" onclick="voteSpot(\'' + spotId + '\',' + n + ')" title="' + n + ' étoile' + (n > 1 ? 's' : '') + '">★</button>').join('') + '</div>'
      : '<div style="font-size:11px;color:var(--text3);margin-top:10px;font-style:italic">Connecte-toi pour voter</div>';

    return (
      '<div class="spot-item">' +
        '<div class="spot-item-header">' +
          '<div class="spot-item-name">' + esc(s.name || 'Spot') + '</div>' +
          '<div class="spot-score-pill">' + score.toFixed(1) + ' ★</div>' +
        '</div>' +
        (badgeHtml ? '<div style="margin-top:6px">' + badgeHtml + '</div>' : '') +
        '<div class="spot-meta">' +
          (s.type ? '<span class="tag-inline">' + esc(s.type) + '</span>' : '') +
          (s.access ? '<span class="tag-inline">' + esc(s.access) + '</span>' : '') +
          '<br>' +
          dangerBar(s.dangerLevel) + ' <span style="font-size:11px;vertical-align:middle"> Danger ' + esc(String(s.dangerLevel || 1)) + '/5</span>' +
          '<br>' + esc(s.region || '—') + ' · ' + esc(s.country || '—') +
          ' · <span style="color:var(--text3)">' + Number(votes) + ' vote' + (votes !== 1 ? 's' : '') + '</span>' +
        '</div>' +
        '<div class="spot-actions">' +
          '<span style="font-family:monospace;font-size:11px;color:var(--text3)">' + Number(s.lat).toFixed(4) + ', ' + Number(s.lon).toFixed(4) + '</span>' +
          '<a href="' + maps + '" target="_blank" rel="noopener" style="font-weight:700;font-size:12px">🗺 Maps</a>' +
          '<a href="/spot/' + spotId + '" target="_blank" rel="noopener" style="font-weight:700;font-size:12px">Détails →</a>' +
        '</div>' +
        voteHtml +
