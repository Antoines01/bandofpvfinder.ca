function getAffiliateLinksFromEnv(env) {
  const raw = String(env?.AFFIL_LINKS || "").trim();
  if (!raw) return {};
  try { const parsed = JSON.parse(raw); if (parsed && typeof parsed === "object") return parsed; return {}; } catch { return {}; }
}

