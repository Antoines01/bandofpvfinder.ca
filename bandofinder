export default {
  async fetch(req, env, ctx) {
    const url = new URL(req.url);

    if (req.method === "OPTIONS") {
      return new Response(null, { headers: cors() });
    }

    try {
      // ─── PayPal: Créer un order ───────────────────────────────────────────
      if (req.method === "POST" && url.pathname === "/buy-credits") {
        if (!env.RESULTS) return json({ error: "KV RESULTS non configuré" }, 500);

        const authUser = await getAuthUser(req, env);
        if (!authUser) return json({ error: "Tu dois être connecté pour acheter des crédits" }, 401);

        const email = authUser.email.toLowerCase();
        const price = String(env?.CREDITS_PRICE || "5.00");
        const currency = String(env?.CREDITS_CURRENCY || "USD");
        const creditsAmount = clampInt(env?.CREDITS_PER_PURCHASE || 5, 1, 100);
        const domain = (env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "");

        const clientId = env?.PAYPAL_CLIENT_ID;
        const clientSecret = env?.PAYPAL_CLIENT_SECRET;
        if (!clientId || !clientSecret) return json({ error: "PayPal non configuré (clés API manquantes)" }, 500);

        const ppBase = (env?.PAYPAL_MODE === "sandbox")
          ? "https://api-m.sandbox.paypal.com"
          : "https://api-m.paypal.com";

        const tokenRes = await fetch(ppBase + "/v1/oauth2/token", {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded",
            "Authorization": "Basic " + btoa(clientId + ":" + clientSecret),
          },
          body: "grant_type=client_credentials",
        });
        const tokenData = await tokenRes.json().catch(() => null);
        if (!tokenRes.ok || !tokenData?.access_token) {
          return json({ error: "Impossible d'obtenir un token PayPal" }, 500);
        }
        const accessToken = tokenData.access_token;

        const orderRes = await fetch(ppBase + "/v2/checkout/orders", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + accessToken,
          },
          body: JSON.stringify({
            intent: "CAPTURE",
            purchase_units: [{
              amount: { currency_code: currency, value: price },
              description: creditsAmount + " crédits — FPV Bando Finder",
            }],
            application_context: {
              brand_name: "FPV Bando Finder",
              return_url: `https://${domain}/paypal/success`,
              cancel_url: `https://${domain}/paypal/cancel`,
              user_action: "PAY_NOW",
              shipping_preference: "NO_SHIPPING",
            },
          }),
        });

        const orderData = await orderRes.json().catch(() => null);
        if (!orderRes.ok || !orderData?.id) {
          return json({ error: "Impossible de créer le paiement PayPal" }, 500);
        }

        await env.RESULTS.put(`paypalOrder/${orderData.id}`, JSON.stringify({
          email,
          credits: creditsAmount,
          createdAt: Date.now(),
        }), {
          expirationTtl: 60 * 60 * 24,
          httpMetadata: { contentType: "application/json; charset=utf-8" },
        });

        const approveLink = (orderData.links || []).find(l => l.rel === "approve");
        if (!approveLink?.href) {
          return json({ error: "Lien de paiement PayPal introuvable" }, 500);
        }

        return json({ checkoutUrl: approveLink.href });
      }

      // ─── PayPal: Capture + crédits ────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/paypal/success") {
        if (!env.RESULTS) return json({ error: "KV non configuré" }, 500);

        const orderId = url.searchParams.get("token") || "";
        if (!orderId) return json({ error: "Order ID manquant" }, 400);

        const orderInfo = await env.RESULTS.get(`paypalOrder/${orderId}`);
        if (!orderInfo) return json({ error: "Order inconnu ou expiré" }, 400);
        const { email, credits: creditsToAdd } = JSON.parse(orderInfo);

        const alreadyProcessed = await env.RESULTS.get(`paypalProcessed/${orderId}`);
        if (alreadyProcessed) {
          return Response.redirect(`https://${(env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "")}/?creditsAdded=${creditsToAdd}`, 302);
        }

        const clientId = env?.PAYPAL_CLIENT_ID;
        const clientSecret = env?.PAYPAL_CLIENT_SECRET;
        const ppBase = (env?.PAYPAL_MODE === "sandbox")
          ? "https://api-m.sandbox.paypal.com"
          : "https://api-m.paypal.com";

        const tokenRes = await fetch(ppBase + "/v1/oauth2/token", {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded",
            "Authorization": "Basic " + btoa(clientId + ":" + clientSecret),
          },
          body: "grant_type=client_credentials",
        });
        const tokenData = await tokenRes.json().catch(() => null);
        if (!tokenRes.ok || !tokenData?.access_token) {
          return json({ error: "Impossible d'obtenir un token PayPal" }, 500);
        }

        const captureRes = await fetch(ppBase + "/v2/checkout/orders/" + orderId + "/capture", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + tokenData.access_token,
          },
        });
        const captureData = await captureRes.json().catch(() => null);

        if (!captureRes.ok || captureData?.status !== "COMPLETED") {
          const domain = (env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "");
          return Response.redirect(`https://${domain}/?pay=error`, 302);
        }

        const creditInfo = await getCreditsData(env, email);
        creditInfo.credits += creditsToAdd;
        await env.RESULTS.put(`credits/${email}`, JSON.stringify(creditInfo), {
          httpMetadata: { contentType: "application/json; charset=utf-8" },
        });

        await env.RESULTS.put(`paypalProcessed/${orderId}`, "1", {
          expirationTtl: 60 * 60 * 24 * 30,
        });

        const domain = (env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "");
        return Response.redirect(`https://${domain}/?creditsAdded=${creditsToAdd}`, 302);
      }

      if (req.method === "GET" && url.pathname === "/paypal/cancel") {
        const domain = (env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "");
        return Response.redirect(`https://${domain}/?pay=cancel`, 302);
      }

      // ─── Page premium ─────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/premium") {
        const html = `<!doctype html><html lang="fr"><head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Crédits — FPV Bando Finder</title>
<style>
body{margin:0;font-family:system-ui;background:#0b0b0b;color:#fff}
.wrap{max-width:760px;margin:0 auto;padding:20px}
.card{border:1px solid #2a2a2a;background:rgba(255,255,255,.04);border-radius:16px;padding:16px}
.muted{color:#aaa;font-size:13px;line-height:1.4}
</style></head><body>
<div class="wrap">
  <div class="card">
    <div class="muted"><a href="/" style="color:#ff6a00">&larr; Retour</a></div>
    <h1 style="margin:8px 0 6px">Acheter des crédits</h1>
    <p class="muted">
      Chaque recherche consomme 1 crédit. Tu reçois 5 crédits gratuits par mois.<br/>
      Besoin de plus ? Achète un pack de 5 crédits pour 5$ via PayPal.
    </p>
  </div>
</div>
</body></html>`;
        return new Response(html, { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      // ─── Static / SEO ─────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/ads.txt") {
        return new Response("google.com, pub-9261647795213017, DIRECT, f08c47fec0942fa0\n", {
          headers: { "Content-Type": "text/plain; charset=utf-8", "Cache-Control": "no-cache, no-store, must-revalidate", ...cors() },
        });
      }

      if (req.method === "GET" && url.pathname === "/bonus") {
        return Response.redirect("https://www.effectivegatecpm.com/rnd9h6c5yu?key=6baf5ce1858ec932c7e07b9cb69d2ac5", 302);
      }

      if (req.method === "GET" && url.pathname === "/robots.txt") {
        const domain = (env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "");
        const txt = "User-agent: *\nAllow: /\nSitemap: https://" + domain + "/sitemap.xml\n";
        return new Response(txt, { headers: { "Content-Type": "text/plain; charset=utf-8", ...cors() } });
      }

      if (req.method === "GET" && url.pathname === "/sitemap.xml") {
        const domain = (env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "");
        const xml = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>https://${domain}/</loc></url>
  <url><loc>https://${domain}/about</loc></url>
  <url><loc>https://${domain}/contact</loc></url>
  <url><loc>https://${domain}/privacy</loc></url>
  <url><loc>https://${domain}/terms</loc></url>
  <url><loc>https://${domain}/gear</loc></url>
  <url><loc>https://${domain}/premium</loc></url>
</urlset>`;
        return new Response(xml, { headers: { "Content-Type": "application/xml; charset=utf-8", ...cors() } });
      }

      // ─── Legal pages ──────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/about") {
        return new Response(legalShell("À propos",
          `<p><b>FPV Bando Finder</b> est un outil communautaire pour repérer des spots (bandos/urbex) de manière responsable.</p>
           <p class="muted">Respecte les lois locales, les propriétés privées et la sécurité.</p>`
        ), { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      if (req.method === "GET" && url.pathname === "/contact") {
        return new Response(legalShell("Contact",
          `<p>Pour nous contacter :</p>
           <ul>
             <li>Email: <a href="mailto:antoinesfpv@gmail.com">antoinesfpv@gmail.com</a></li>
             <li>Instagram: <a href="https://instagram.com/AntoineS.FPV" target="_blank" rel="noopener">@AntoineS.FPV</a></li>
           </ul>`
        ), { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      if (req.method === "GET" && url.pathname === "/privacy") {
        return new Response(legalShell("Politique de confidentialité",
          `<p>Nous stockons uniquement ce qui est nécessaire au fonctionnement (sessions, spots partagés, votes).</p>
           <p>Nous ne vendons pas tes données. Les spots sont publics et consultables via leur lien.</p>
           <p class="muted">Des publicités peuvent être servies par des partenaires (ex: Google AdSense).</p>`
        ), { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      if (req.method === "GET" && url.pathname === "/terms") {
        return new Response(legalShell("Conditions d'utilisation",
          `<p>En utilisant ce site, tu acceptes de voler de manière légale et sécuritaire.</p>
           <p>Les spots sont partagés par la communauté; aucune garantie sur l'exactitude ou l'accessibilité.</p>
           <p class="muted">Ne force jamais l'accès à une propriété privée. Tu es responsable de tes actions.</p>`
        ), { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      // ─── Affiliate ────────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/gear") {
        const links = getAffiliateLinksFromEnv(env);
        const html = buildGearHTML(links, env, url);
        return new Response(html, { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      if (req.method === "GET" && url.pathname.startsWith("/go/")) {
        if (!env.RESULTS) return new Response("KV missing", { status: 500, headers: cors() });
        const slug = (url.pathname.split("/").pop() || "").trim().toLowerCase();
        const links = getAffiliateLinksFromEnv(env);
        const target = links?.[slug]?.url;
        if (!slug || !target) return new Response("Unknown affiliate link", { status: 404, headers: cors() });
        const key = `affil/clicks/${slug}`;
        const current = Number(await env.RESULTS.get(key)) || 0;
        await env.RESULTS.put(key, String(current + 1), { httpMetadata: { contentType: "text/plain; charset=utf-8" } });
        return Response.redirect(String(target), 302);
      }

      if (req.method === "GET" && url.pathname === "/admin/affil-stats") {
        if (!env.RESULTS) return json({ error: "KV non configuré" }, 500);
        const user = await getAuthUser(req, env);
        if (!user || !isAdminEmail(user.email, env)) return json({ error: "Forbidden" }, 403);
        const links = getAffiliateLinksFromEnv(env);
        const out = [];
        for (const slug of Object.keys(links)) {
          const clicks = Number(await env.RESULTS.get(`affil/clicks/${slug}`)) || 0;
          out.push({ slug, name: links[slug].name || slug, clicks, url: links[slug].url });
        }
        out.sort((a, b) => (b.clicks || 0) - (a.clicks || 0));
        return json({ items: out });
      }

      // ─── UI principale ────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/") {
        return new Response(uiHTML(), { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      // ─── KV requis ────────────────────────────────────────────────────────
      const needsKVPrefixes = [
        "/register", "/login", "/logout", "/change-password",
        "/admin/reset-password", "/me", "/generate", "/submit-spot",
        "/vote-spot", "/top-spots", "/regions", "/admin/hide-spot", "/admin/unhide-spot",
      ];
      const isKVRoute =
        needsKVPrefixes.includes(url.pathname) ||
        url.pathname.startsWith("/spot/") ||
        url.pathname.startsWith("/results/");

      if (isKVRoute && !env.RESULTS) {
        return json({ error: "KV RESULTS non configuré" }, 500);
      }

      // ─── Auth ─────────────────────────────────────────────────────────────
      if (req.method === "POST" && url.pathname === "/register") {
        const body = await req.json().catch(() => ({}));
        const email = String(body.email || "").trim().toLowerCase();
        const password = String(body.password || "");
        const displayName = String(body.displayName || "").trim();

        if (!email || !email.includes("@")) return json({ error: "Email valide requis" }, 400);
        if (password.length < 8) return json({ error: "Mot de passe (min 8 caractères) requis" }, 400);

        const existingUserId = await env.RESULTS.get(`userByEmail/${email}`);
        if (existingUserId) return json({ error: "Ce email est déjà utilisé" }, 409);

        const userId = crypto.randomUUID();
        const iter = clampInt(env?.PBKDF2_ITER || 60000, 10000, 200000);
        const saltB64 = bytesToB64(crypto.getRandomValues(new Uint8Array(16)));
        const hashB64 = await hashPasswordPBKDF2(password, saltB64, iter);

        const user = {
          id: userId, email,
          displayName: displayName || email.split("@")[0],
          role: "user",
          pw: { algo: "PBKDF2-SHA256", iter, saltB64, hashB64 },
          createdAt: new Date().toISOString(),
        };

        await env.RESULTS.put(`users/${userId}`, JSON.stringify(user), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
        await env.RESULTS.put(`userByEmail/${email}`, userId, { httpMetadata: { contentType: "text/plain; charset=utf-8" } });

        const INITIAL_CREDITS = clampInt(env?.MONTHLY_CREDITS || 5, 1, 500);
        const initialCreditData = { credits: INITIAL_CREDITS, resetAt: Date.now() + (30 * 24 * 60 * 60 * 1000) };
        await env.RESULTS.put(`credits/${email}`, JSON.stringify(initialCreditData), { httpMetadata: { contentType: "application/json; charset=utf-8" } });

        const token = crypto.randomUUID();
        await env.RESULTS.put(`sessions/${token}`, userId, { expirationTtl: 60 * 60 * 24 * 14, httpMetadata: { contentType: "text/plain; charset=utf-8" } });

        return json({ status: "ok", token, user: { id: userId, email, displayName: user.displayName }, credits: INITIAL_CREDITS });
      }

      if (req.method === "POST" && url.pathname === "/login") {
        const body = await req.json().catch(() => ({}));
        const email = String(body.email || "").trim().toLowerCase();
        const password = String(body.password || "");

        if (!email || !email.includes("@")) return json({ error: "Email valide requis" }, 400);
        if (!password) return json({ error: "Mot de passe requis" }, 400);

        const userId = await env.RESULTS.get(`userByEmail/${email}`);
        if (!userId) return json({ error: "Email ou mot de passe invalide" }, 401);

        const userRaw = await env.RESULTS.get(`users/${userId}`);
        if (!userRaw) return json({ error: "Email ou mot de passe invalide" }, 401);

        let user;
        try { user = JSON.parse(userRaw); } catch { return json({ error: "Compte corrompu" }, 500); }

        const { saltB64, hashB64, iter: savedIter } = user?.pw || {};
        if (!saltB64 || !hashB64) return json({ error: "Compte invalide" }, 500);

        const iter = clampInt(savedIter || env?.PBKDF2_ITER || 60000, 10000, 200000);
        const testHash = await hashPasswordPBKDF2(password, saltB64, iter);
        if (!timingSafeEqualB64(testHash, hashB64)) return json({ error: "Email ou mot de passe invalide" }, 401);

        const token = crypto.randomUUID();
        await env.RESULTS.put(`sessions/${token}`, String(userId), { expirationTtl: 60 * 60 * 24 * 14, httpMetadata: { contentType: "text/plain; charset=utf-8" } });

        const loginCredits = await getCreditsData(env, user.email);
        return json({ status: "ok", token, user: { id: user.id, email: user.email, displayName: user.displayName }, credits: loginCredits.credits, credits_reset_at: new Date(loginCredits.resetAt).toISOString() });
      }

      if (req.method === "POST" && url.pathname === "/logout") {
        const token = getBearerToken(req);
        if (!token) return json({ error: "Non authentifié" }, 401);
        await env.RESULTS.delete(`sessions/${token}`);
        return json({ status: "ok" });
      }

      if (req.method === "POST" && url.pathname === "/change-password") {
        const authUser = await getAuthUser(req, env);
        if (!authUser) return json({ error: "Non authentifié. Connecte-toi d'abord." }, 401);

        const body = await req.json().catch(() => ({}));
        const oldPassword = String(body.oldPassword || "");
        const newPassword = String(body.newPassword || "");

        if (!oldPassword) return json({ error: "Ancien mot de passe requis" }, 400);
        if (newPassword.length < 8) return json({ error: "Nouveau mot de passe (min 8 caractères) requis" }, 400);

        const { saltB64, hashB64, iter: savedIter } = authUser?.pw || {};
        if (!saltB64 || !hashB64) return json({ error: "Compte invalide" }, 500);
        const oldIter = clampInt(savedIter || env?.PBKDF2_ITER || 60000, 10000, 200000);
        const testHash = await hashPasswordPBKDF2(oldPassword, saltB64, oldIter);
        if (!timingSafeEqualB64(testHash, hashB64)) return json({ error: "Ancien mot de passe incorrect" }, 401);

        const iter = clampInt(env?.PBKDF2_ITER || 60000, 10000, 200000);
        const newSaltB64 = bytesToB64(crypto.getRandomValues(new Uint8Array(16)));
        const newHashB64 = await hashPasswordPBKDF2(newPassword, newSaltB64, iter);
        authUser.pw = { algo: "PBKDF2-SHA256", iter, saltB64: newSaltB64, hashB64: newHashB64 };
        await env.RESULTS.put(`users/${authUser.id}`, JSON.stringify(authUser), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
        return json({ status: "ok", message: "Mot de passe modifié avec succès" });
      }

      if (req.method === "POST" && url.pathname === "/admin/reset-password") {
        const adminUser = await getAuthUser(req, env);
        if (!adminUser) return json({ error: "Non authentifié" }, 401);
        if (!isAdminEmail(adminUser.email, env)) return json({ error: "Accès refusé — admin uniquement" }, 403);

        const body = await req.json().catch(() => ({}));
        const targetEmail = String(body.email || "").trim().toLowerCase();
        const newPassword = String(body.newPassword || "");

        if (!targetEmail || !targetEmail.includes("@")) return json({ error: "Email valide requis" }, 400);
        if (newPassword.length < 8) return json({ error: "Nouveau mot de passe (min 8 caractères) requis" }, 400);

        const userId = await env.RESULTS.get(`userByEmail/${targetEmail}`);
        if (!userId) return json({ error: "Aucun compte trouvé avec cet email" }, 404);

        const userRaw = await env.RESULTS.get(`users/${userId}`);
        if (!userRaw) return json({ error: "Compte introuvable" }, 404);

        let user;
        try { user = JSON.parse(userRaw); } catch { return json({ error: "Compte corrompu" }, 500); }

        const iter = clampInt(env?.PBKDF2_ITER || 60000, 10000, 200000);
        const newSaltB64 = bytesToB64(crypto.getRandomValues(new Uint8Array(16)));
        const newHashB64 = await hashPasswordPBKDF2(newPassword, newSaltB64, iter);
        user.pw = { algo: "PBKDF2-SHA256", iter, saltB64: newSaltB64, hashB64: newHashB64 };
        await env.RESULTS.put(`users/${userId}`, JSON.stringify(user), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
        return json({ status: "ok", message: "Mot de passe de " + targetEmail + " réinitialisé" });
      }

      if (req.method === "GET" && url.pathname === "/me") {
        const user = await getAuthUser(req, env);
        if (!user) return json({ error: "Non authentifié" }, 401);
        const admin = isAdminEmail(user.email, env);
        const creditsData = await getCreditsData(env, user.email);
        return json({
          user: { id: user.id, email: user.email, displayName: user.displayName, role: admin ? "admin" : user.role || "user" },
          credits: creditsData.credits,
          credits_reset_at: new Date(creditsData.resetAt).toISOString(),
        });
      }

      // ─── Search / Generate ────────────────────────────────────────────────
      if (req.method === "POST" && url.pathname === "/generate") {
        const body = await req.json().catch(() => ({}));
        if (!body.email || !String(body.email).includes("@")) return json({ error: "Email valide requis" }, 400);
        if (!body.city) return json({ error: "Ville ou région requise" }, 400);
        if (!body.country) return json({ error: "Pays requis" }, 400);

        const q = `${String(body.city).trim()}, ${String(body.country).trim()}`.trim();
        const geo = await geocode(q);
        if (!geo) return json({ error: "Geocoding failed (Nominatim)" }, 400);

        const radiusKm = clampNumber(body.radiusKm ?? 15, 1, 60);
        const osmSpots = await searchBandos(geo.lat, geo.lon, radiusKm);

        const includeWebRequested = body.includeWeb === true;
        const webMax = clampInt(body.webMax ?? 6, 1, 10);
        let webCandidates = [];
        let webEnabled = false;
        let premium = false;

        if (includeWebRequested) {
          const emailLower = String(body.email || "").trim().toLowerCase();
          premium = await hasPremiumAccess(env, emailLower);
          if (premium) {
            webEnabled = true;
            webCandidates = await searchWebCandidates({ env, city: String(body.city || "").trim(), country: String(body.country || "").trim(), center: { lat: geo.lat, lon: geo.lon }, radiusKm, maxResults: webMax });
          }
        }

        const emailLower = String(body.email || "").trim().toLowerCase();
        const creditCheck = await useCredit(env, emailLower);
        if (!creditCheck.ok) {
          return json({
            error: "PLUS DE CRÉDITS",
            message: "Tu n'as plus de crédits pour faire une recherche.",
            solution: ["Acheter des crédits (Premium)", "Attendre 30 jours pour le reset"],
            credits: creditCheck.data.credits,
            reset_at: new Date(creditCheck.data.resetAt).toISOString(),
          }, 402);
        }

        const spots = [
          ...(osmSpots || []).map(s => ({ ...s, source: "osm" })),
          ...(webCandidates || []).map(s => ({ ...s, source: "web" })),
        ];

        const html = buildHTML(geo.lat, geo.lon, spots, q);
        const id = crypto.randomUUID();
        const key = `results/${id}.html`;
        await env.RESULTS.put(key, html, { httpMetadata: { contentType: "text/html; charset=utf-8" } });

        const domain = (env.PUBLIC_DOMAIN || url.host || "").replace(/^https?:\/\//, "");
        const premiumRequired = includeWebRequested && !premium;

        return json({
          status: "done", query: q,
          spots_found: spots.length,
          osm_found: (osmSpots || []).length,
          web_found: (webCandidates || []).length,
          web_enabled: webEnabled, premium,
          premium_required: premiumRequired,
          message: premiumRequired ? "Recherche Web désactivée (Premium requis). Résultats OSM seulement." : (webEnabled ? "Recherche Web activée (Premium)." : "Résultats OSM."),
          url: `https://${domain}/${key}`,
          spots,
          credits_remaining: creditCheck.data.credits,
          credits_reset_at: new Date(creditCheck.data.resetAt).toISOString(),
        });
      }

      // ─── Results page ─────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname.startsWith("/results/")) {
        const key = url.pathname.slice(1);
        const html = await env.RESULTS.get(key);
        if (!html) return new Response("Not found", { status: 404, headers: cors() });
        return new Response(html, { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      // ─── Submit spot ──────────────────────────────────────────────────────
      if (req.method === "POST" && url.pathname === "/submit-spot") {
        const body = await req.json().catch(() => ({}));
        const name = String(body.name || "").trim();
        const lat = Number(body.lat);
        const lon = Number(body.lon);

        if (!name) return json({ error: "Nom requis" }, 400);
        if (!Number.isFinite(lat) || !Number.isFinite(lon)) return json({ error: "Latitude/Longitude invalides" }, 400);

        const desc = String(body.desc || "").trim().slice(0, 1200);
        const email = String(body.email || "").trim().toLowerCase().slice(0, 120);
        const type = String(body.type || "").trim().slice(0, 80);
        const access = String(body.access || "").trim().slice(0, 30);
        const dangerLevel = clampInt(body.dangerLevel || 1, 1, 5);
        const ownerName = String(body.ownerName || "").trim().slice(0, 60);

        let region = String(body.region || "").trim().slice(0, 80);
        let country = String(body.country || "").trim().slice(0, 80);

        if (!region || !country) {
          const rg = await reverseGeocode(lat, lon);
          if (!region) region = rg.region || "";
          if (!country) country = rg.country || "";
        }

        const spotId = crypto.randomUUID();
        const spot = {
          id: spotId, name,
          lat: clampFloat(lat, -90, 90, 6), lon: clampFloat(lon, -180, 180, 6),
          desc, email, type, access, dangerLevel, ownerName, region, country,
          createdAt: new Date().toISOString(),
          hidden: false, hiddenReason: "", hiddenAt: "",
          score: 0, votes: 0,
        };

        await env.RESULTS.put(`spots/${spotId}`, JSON.stringify(spot), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
        await appendSpotLog(env, spotId, { t: Date.now(), kind: "created" });
        return json({ status: "ok", id: spotId });
      }

      // ─── Spot page ────────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname.startsWith("/spot/")) {
        const spotId = decodeURIComponent(url.pathname.split("/").pop() || "").trim();
        if (!spotId) return new Response("Not found", { status: 404, headers: cors() });

        const raw = await env.RESULTS.get(`spots/${spotId}`);
        if (!raw) return new Response("Not found", { status: 404, headers: cors() });

        let spot;
        try { spot = JSON.parse(raw); } catch { return new Response("Corrupted spot", { status: 500, headers: cors() }); }

        if (spot.hidden === true) {
          return new Response(legalShell("Spot indisponible", `<p>Ce spot est actuellement indisponible (masqué).</p>`), {
            headers: { "Content-Type": "text/html; charset=utf-8", ...cors() }, status: 200,
          });
        }

        const logsRaw = await env.RESULTS.get(`logs/${spotId}`);
        let logs = [];
        try { logs = logsRaw ? JSON.parse(logsRaw) : []; if (!Array.isArray(logs)) logs = []; } catch { logs = []; }

        const html = buildSpotPageHTML(spot, logs, env, url);
        return new Response(html, { headers: { "Content-Type": "text/html; charset=utf-8", ...cors() } });
      }

      // ─── Vote ─────────────────────────────────────────────────────────────
      if (req.method === "POST" && url.pathname === "/vote-spot") {
        const user = await getAuthUser(req, env);
        if (!user) return json({ error: "Non authentifié" }, 401);

        const body = await req.json().catch(() => ({}));
        const spotId = String(body.spotId || "").trim();
        const stars = clampInt(body.stars || 0, 1, 5);
        if (!spotId) return json({ error: "spotId requis" }, 400);

        const raw = await env.RESULTS.get(`spots/${spotId}`);
        if (!raw) return json({ error: "Spot introuvable" }, 404);

        const spot = JSON.parse(raw);
        if (spot.hidden === true) return json({ error: "Spot indisponible" }, 403);

        const voteKey = `votes/${spotId}/${user.id}`;
        const already = await env.RESULTS.get(voteKey);
        if (already) return json({ error: "Tu as déjà voté pour ce spot." }, 409);

        const prevVotes = Number(spot.votes || 0);
        const prevScore = Number(spot.score || 0);
        const newVotes = prevVotes + 1;
        const newScore = (prevScore * prevVotes + stars) / newVotes;
        spot.votes = newVotes;
        spot.score = Number(newScore.toFixed(6));

        if (spot.votes >= 8 && spot.score <= 1.2) {
          spot.hidden = true;
          spot.hiddenReason = "auto:low_score";
          spot.hiddenAt = new Date().toISOString();
        }

        await env.RESULTS.put(`spots/${spotId}`, JSON.stringify(spot), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
        await env.RESULTS.put(voteKey, String(stars), { httpMetadata: { contentType: "text/plain; charset=utf-8" }, expirationTtl: 60 * 60 * 24 * 365 });
        await appendSpotLog(env, spotId, { t: Date.now(), kind: "vote", stars, score: spot.score, votes: spot.votes, hidden: spot.hidden === true });

        return json({ status: "ok", score: spot.score, votes: spot.votes, hidden: spot.hidden === true });
      }

      // ─── Top spots ────────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/top-spots") {
        const region = String(url.searchParams.get("region") || "").trim();
        const country = String(url.searchParams.get("country") || "").trim();
        const spots = await listAllSpots(env);
        const filtered = spots
          .filter(s => s && s.hidden !== true)
          .filter(s => region ? String(s.region || "").trim() === region : true)
          .filter(s => country ? String(s.country || "").trim() === country : true)
          .map(minimalSpotForUI);
        filtered.sort((a, b) => (b.scoreDisplayed || 0) - (a.scoreDisplayed || 0));
        return json({ spots: filtered.slice(0, 10) });
      }

      // ─── Regions ──────────────────────────────────────────────────────────
      if (req.method === "GET" && url.pathname === "/regions") {
        const spots = await listAllSpots(env);
        const reg = new Set();
        const cou = new Set();
        for (const s of spots) {
          if (!s || s.hidden === true) continue;
          const r = String(s.region || "").trim();
          const c = String(s.country || "").trim();
          if (r) reg.add(r);
          if (c) cou.add(c);
        }
        const regions = Array.from(reg).sort((a, b) => a.localeCompare(b, "fr"));
        const countries = Array.from(cou).sort((a, b) => a.localeCompare(b, "fr"));
        return json({ regions, countries });
      }

      // ─── Moderation ───────────────────────────────────────────────────────
      if (req.method === "POST" && url.pathname === "/admin/hide-spot") {
        const user = await getAuthUser(req, env);
        if (!user || !isAdminEmail(user.email, env)) return json({ error: "Forbidden" }, 403);
        const body = await req.json().catch(() => ({}));
        const spotId = String(body.spotId || "").trim();
        const reason = String(body.reason || "admin").slice(0, 80);
        if (!spotId) return json({ error: "spotId requis" }, 400);
        const key = `spots/${spotId}`;
        const raw = await env.RESULTS.get(key);
        if (!raw) return json({ error: "Spot introuvable" }, 404);
        const spot = JSON.parse(raw);
        spot.hidden = true;
        spot.hiddenReason = "admin:" + reason;
        spot.hiddenAt = new Date().toISOString();
        await env.RESULTS.put(key, JSON.stringify(spot), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
        await appendSpotLog(env, spotId, { t: Date.now(), kind: "admin_hide", reason });
        return json({ status: "ok" });
      }

      if (req.method === "POST" && url.pathname === "/admin/unhide-spot") {
        const user = await getAuthUser(req, env);
        if (!user || !isAdminEmail(user.email, env)) return json({ error: "Forbidden" }, 403);
        const body = await req.json().catch(() => ({}));
        const spotId = String(body.spotId || "").trim();
        if (!spotId) return json({ error: "spotId requis" }, 400);
        const key = `spots/${spotId}`;
        const raw = await env.RESULTS.get(key);
        if (!raw) return json({ error: "Spot introuvable" }, 404);
        const spot = JSON.parse(raw);
        spot.hidden = false;
        spot.hiddenReason = "";
        spot.hiddenAt = "";
        await env.RESULTS.put(key, JSON.stringify(spot), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
        await appendSpotLog(env, spotId, { t: Date.now(), kind: "admin_unhide" });
        return json({ status: "ok" });
      }

      return new Response("Not found", { status: 404, headers: cors() });
    } catch (e) {
      return json({ error: "Worker error", message: String(e?.message || e), stack: String(e?.stack || "") }, 500);
    }
  },
};

/* ═══════════════ JSON / CORS ═══════════════ */
function json(data, status = 200) {
  return new Response(JSON.stringify(data), {
    status,
    headers: { "Content-Type": "application/json; charset=utf-8", ...cors() },
  });
}
function cors() {
  return {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET,POST,OPTIONS",
    "Access-Control-Allow-Headers": "*",
  };
}

/* ═══════════════ Utils ═══════════════ */
function clampNumber(v, min, max) { const n = Number(v); if (Number.isNaN(n)) return min; return Math.min(max, Math.max(min, n)); }
function clampInt(v, min, max) { const n = Number(v); if (!Number.isFinite(n)) return min; return Math.min(max, Math.max(min, Math.round(n))); }
function clampFloat(v, min, max, decimals = 6) { let n = Number(v); if (!Number.isFinite(n)) n = min; n = Math.min(max, Math.max(min, n)); const p = Math.pow(10, decimals); return Math.round(n * p) / p; }
function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, m => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[m]));
}

/* ═══════════════ Auth helpers ═══════════════ */
function getBearerToken(req) {
  const h = req.headers.get("Authorization") || req.headers.get("authorization") || "";
  const m = h.match(/^Bearer\s+(.+)$/i);
  return m ? m[1].trim() : "";
}
async function getAuthUser(req, env) {
  const token = getBearerToken(req);
  if (!token) return null;
  const userId = await env.RESULTS.get(`sessions/${token}`);
  if (!userId) return null;
  const raw = await env.RESULTS.get(`users/${userId}`);
  if (!raw) return null;
  try { return JSON.parse(raw); } catch { return null; }
}
function isAdminEmail(email, env) {
  const e = String(email || "").trim().toLowerCase();
  if (!e) return false;
  if (e === "antoinesfpv@gmail.com") return true;
  const single = String(env?.ADMIN_EMAIL || "").trim().toLowerCase();
  if (single && e === single) return true;
  const list = String(env?.ADMIN_EMAILS || "").split(",").map(s => s.trim().toLowerCase()).filter(Boolean);
  return list.includes(e);
}

/* ═══════════════ Crédits ═══════════════ */
async function getCreditsData(env, email) {
  const MONTHLY = clampInt(env?.MONTHLY_CREDITS || 5, 1, 500);
  const ADMIN_CREDITS = 9999999;
  const admin = isAdminEmail(email, env);
  const key = `credits/${email}`;
  const raw = await env.RESULTS.get(key);
  let data = null;
  if (raw) { try { data = JSON.parse(raw); } catch { data = null; } }
  if (!data || typeof data.credits !== "number" || typeof data.resetAt !== "number") {
    data = { credits: admin ? ADMIN_CREDITS : MONTHLY, resetAt: Date.now() + (30 * 24 * 60 * 60 * 1000) };
    await env.RESULTS.put(key, JSON.stringify(data), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
    return data;
  }
  if (Date.now() >= data.resetAt) {
    data.credits = admin ? ADMIN_CREDITS : MONTHLY;
    data.resetAt = Date.now() + (30 * 24 * 60 * 60 * 1000);
    await env.RESULTS.put(key, JSON.stringify(data), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
  }
  if (admin && data.credits < ADMIN_CREDITS) {
    data.credits = ADMIN_CREDITS;
    await env.RESULTS.put(key, JSON.stringify(data), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
  }
  return data;
}

async function useCredit(env, email) {
  const key = `credits/${email}`;
  const data = await getCreditsData(env, email);
  if (data.credits <= 0) return { ok: false, data };
  data.credits -= 1;
  await env.RESULTS.put(key, JSON.stringify(data), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
  return { ok: true, data };
}

async function hasPremiumAccess(env, email) {
  if (!env?.RESULTS) return false;
  const raw = await env.RESULTS.get(`premium/${email}`);
  if (!raw) return false;
  try { const data = JSON.parse(raw); const until = new Date(data.until).getTime(); return Date.now() < until; } catch { return false; }
}

/* ═══════════════ PBKDF2 ═══════════════ */
async function hashPasswordPBKDF2(password, saltB64, iterations = 60000) {
  iterations = Math.max(10000, Math.min(200000, Number(iterations) || 60000));
  const salt = b64ToBytes(saltB64);
  const enc = new TextEncoder();
  const keyMaterial = await crypto.subtle.importKey("raw", enc.encode(password), { name: "PBKDF2" }, false, ["deriveBits"]);
  const bits = await crypto.subtle.deriveBits({ name: "PBKDF2", salt, iterations, hash: "SHA-256" }, keyMaterial, 256);
  return bytesToB64(new Uint8Array(bits));
}
function timingSafeEqualB64(a, b) {
  const ab = String(a), bb = String(b);
  if (ab.length !== bb.length) return false;
  let out = 0;
  for (let i = 0; i < ab.length; i++) out |= ab.charCodeAt(i) ^ bb.charCodeAt(i);
  return out === 0;
}
function bytesToB64(bytes) { let s = ""; for (let i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]); return btoa(s); }
function b64ToBytes(b64) { const bin = atob(String(b64)); const out = new Uint8Array(bin.length); for (let i = 0; i < bin.length; i++) out[i] = bin.charCodeAt(i); return out; }

/* ═══════════════ Geocode (Nominatim) ═══════════════ */
async function geocode(query) {
  const controller = new AbortController();
  const t = setTimeout(() => controller.abort(), 8000);
  try {
    const u = "https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=" + encodeURIComponent(query);
    const res = await fetch(u, { method: "GET", headers: { "User-Agent": "FPV-Bando-Finder (Cloudflare Worker)", Accept: "application/json" }, signal: controller.signal });
    if (!res.ok) return null;
    const arr = await res.json();
    if (!Array.isArray(arr) || !arr[0]) return null;
    const lat = Number(arr[0].lat), lon = Number(arr[0].lon);
    if (Number.isNaN(lat) || Number.isNaN(lon)) return null;
    return { lat, lon, display_name: arr[0].display_name || query };
  } finally { clearTimeout(t); }
}

async function reverseGeocode(lat, lon) {
  const controller = new AbortController();
  const t = setTimeout(() => controller.abort(), 8000);
  try {
    const u = "https://nominatim.openstreetmap.org/reverse?format=jsonv2&zoom=10&addressdetails=1&lat=" + encodeURIComponent(String(lat)) + "&lon=" + encodeURIComponent(String(lon));
    const res = await fetch(u, { method: "GET", headers: { "User-Agent": "FPV-Bando-Finder (Cloudflare Worker)", Accept: "application/json" }, signal: controller.signal });
    if (!res.ok) return { region: "", country: "" };
    const data = await res.json().catch(() => null);
    const addr = data?.address || {};
    const region = addr.state || addr.province || addr.region || addr.county || addr.city || addr.town || addr.village || "";
    const country = addr.country || "";
    return { region: String(region || "").trim(), country: String(country || "").trim() };
  } catch { return { region: "", country: "" }; } finally { clearTimeout(t); }
}

/* ═══════════════ Search (Overpass) ═══════════════ */
async function searchBandos(lat, lon, radiusKm = 15) {
  const km = Number(radiusKm);
  const safeKm = Number.isFinite(km) ? km : 15;
  const clampedKm = Math.min(Math.max(safeKm, 1), 30);
  const radius = Math.round(clampedKm * 1000);

  const overpassQuery = `
[out:json][timeout:20];
(
  nwr(around:${radius},${lat},${lon})["abandoned"="yes"];
  nwr(around:${radius},${lat},${lon})["building"="abandoned"];
  nwr(around:${radius},${lat},${lon})["ruins"="yes"];
  nwr(around:${radius},${lat},${lon})["historic"="ruins"];
  nwr(around:${radius},${lat},${lon})["man_made"="works"]["disused"="yes"];
  nwr(around:${radius},${lat},${lon})["landuse"="industrial"]["disused"="yes"];
  nwr(around:${radius},${lat},${lon})["disused"="yes"];
);
out center qt;
`;

  const controller = new AbortController();
  const t = setTimeout(() => controller.abort(), 23000);
  try {
    const res = await fetch("https://overpass-api.de/api/interpreter", {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded; charset=utf-8", Accept: "application/json", "User-Agent": "FPV-Bando-Finder (Cloudflare Worker)" },
      body: "data=" + encodeURIComponent(overpassQuery),
      signal: controller.signal,
    });
    if (!res.ok) return [];
    const data = await res.json();
    const elements = Array.isArray(data?.elements) ? data.elements : [];
    const spots = elements.map(el => {
      const cLat = Number(el.lat ?? el.center?.lat);
      const cLon = Number(el.lon ?? el.center?.lon);
      if (!Number.isFinite(cLat) || !Number.isFinite(cLon)) return null;
      const tags = el.tags || {};
      const name = tags.name || tags["addr:housename"] || tags.operator || tags.brand || "Spot (sans nom)";
      const desc = tags.description || tags.note || tags["addr:full"] || tags["addr:street"] || "";
      return { id: String(el.id), name, lat: cLat, lon: cLon, desc };
    }).filter(Boolean);
    const seen = new Set();
    const uniq = [];
    for (const s of spots) {
      const k = `${s.lat.toFixed(6)}|${s.lon.toFixed(6)}|${s.name}`;
      if (seen.has(k)) continue;
      seen.add(k);
      uniq.push(s);
    }
    return uniq;
  } finally { clearTimeout(t); }
}

/* ═══════════════ Web candidates (SerpApi) ═══════════════ */
async function searchWebCandidates({ env, city, country, center, radiusKm, maxResults = 6 }) {
  const apiKey = String(env?.SERP_API_KEY || "").trim();
  if (!apiKey) return [];
  const safeMax = clampInt(maxResults, 1, 10);
  const cacheKey = `webcache/${(city + "," + country).toLowerCase()}/${Math.round(radiusKm)}/${safeMax}`;
  const cached = await kvGetJson(env, cacheKey);
  if (cached && Array.isArray(cached)) return cached;
  const query = buildWebQuery(city, country);
  const items = await serpWebSearch(query, apiKey, safeMax);
  if (!items.length) { await kvPutJson(env, cacheKey, [], 60 * 60 * 12); return []; }
  const maxGeocode = Math.min(4, items.length);
  const out = [];
  for (let i = 0; i < items.length; i++) {
    if (out.length >= maxGeocode) break;
    const it = items[i];
    if (!it?.name || !it?.url) continue;
    const guess = `${it.name}, ${city}, ${country}`;
    const g = await geocode(guess).catch(() => null);
    if (!g) continue;
    const dKm = haversineKm(center.lat, center.lon, g.lat, g.lon);
    if (dKm > Number(radiusKm) + 2) continue;
    out.push({ id: "web-" + hashMini(it.url), name: it.name.slice(0, 90), lat: clampFloat(g.lat, -90, 90, 6), lon: clampFloat(g.lon, -180, 180, 6), desc: String(it.snippet || "").slice(0, 220), web: { title: it.name, url: it.url, snippet: it.snippet || "", source: "serpapi" } });
  }
  const seen = new Set();
  const uniq = [];
  for (const s of out) {
    const k = `${s.lat.toFixed(5)}|${s.lon.toFixed(5)}|${(s.name || "").toLowerCase()}`;
    if (seen.has(k)) continue;
    seen.add(k);
    uniq.push(s);
  }
  await kvPutJson(env, cacheKey, uniq, 60 * 60 * 12);
  return uniq;
}

function buildWebQuery(city, country) {
  const place = `${city} ${country}`.trim();
  const kw = [`"abandoned"`, `"urbex"`, `"abandoned factory"`, `"abandoned building"`, `"friche industrielle"`, `"usine abandonnée"`, `"bâtiment abandonné"`, `"désaffecté"`, `"ruins"`, `"closed plant"`, `"abandoned mall"`].join(" OR ");
  return `(${kw}) ${place}`;
}

async function serpWebSearch(query, apiKey, count = 6) {
  const controller = new AbortController();
  const t = setTimeout(() => controller.abort(), 8000);
  try {
    const u = new URL("https://serpapi.com/search.json");
    u.searchParams.set("q", query);
    u.searchParams.set("api_key", apiKey);
    u.searchParams.set("engine", "google");
    u.searchParams.set("num", String(count));
    u.searchParams.set("hl", "en");
    u.searchParams.set("gl", "ca");
    const res = await fetch(u.toString(), { signal: controller.signal });
    if (!res.ok) return [];
    const data = await res.json().catch(() => ({}));
    const arr = Array.isArray(data.organic_results) ? data.organic_results : [];
    return arr.map(r => ({ name: String(r?.title || "").trim(), url: String(r?.link || "").trim(), snippet: String(r?.snippet || "").trim() })).filter(x => x.name && x.url);
  } catch { return []; } finally { clearTimeout(t); }
}

/* ═══════════════ KV helpers ═══════════════ */
async function kvGetJson(env, key) {
  try { if (!env?.RESULTS) return null; const raw = await env.RESULTS.get(key); if (!raw) return null; return JSON.parse(raw); } catch { return null; }
}
async function kvPutJson(env, key, obj, ttlSeconds = 3600) {
  try { if (!env?.RESULTS) return; await env.RESULTS.put(key, JSON.stringify(obj), { expirationTtl: clampInt(ttlSeconds, 60, 60 * 60 * 24 * 7), httpMetadata: { contentType: "application/json; charset=utf-8" } }); } catch {}
}

/* ═══════════════ Distance + hash ═══════════════ */
function haversineKm(lat1, lon1, lat2, lon2) {
  const R = 6371;
  const toRad = d => (d * Math.PI) / 180;
  const dLat = toRad(lat2 - lat1), dLon = toRad(lon2 - lon1);
  const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
  return 2 * R * Math.asin(Math.sqrt(a));
}
function hashMini(str) {
  const s = String(str || "");
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) { h ^= s.charCodeAt(i); h = Math.imul(h, 16777619); }
  return (h >>> 0).toString(16);
}

/* ═══════════════ Logs ═══════════════ */
async function appendSpotLog(env, spotId, event) {
  try {
    if (!env?.RESULTS) return;
    const key = `logs/${spotId}`;
    const raw = await env.RESULTS.get(key);
    let arr = [];
    try { arr = raw ? JSON.parse(raw) : []; if (!Array.isArray(arr)) arr = []; } catch { arr = []; }
    arr.push(event);
    if (arr.length > 30) arr = arr.slice(arr.length - 30);
    await env.RESULTS.put(key, JSON.stringify(arr), { httpMetadata: { contentType: "application/json; charset=utf-8" } });
  } catch {}
}

/* ═══════════════ List all spots ═══════════════ */
async function listAllSpots(env) {
  const out = [];
  let cursor = undefined;
  do {
    const res = await env.RESULTS.list({ prefix: "spots/", cursor, limit: 1000 });
    cursor = res?.cursor;
    const keys = Array.isArray(res?.keys) ? res.keys : [];
    for (const k of keys) {
      const raw = await env.RESULTS.get(k.name);
      if (!raw) continue;
      try { out.push(JSON.parse(raw)); } catch {}
    }
    if (!res?.list_complete) break;
  } while (cursor);
  return out;
}

/* ═══════════════ Scoring / Badges ═══════════════ */
function computeScoreDisplayed(score, votes) {
  const s = Number(score || 0), v = Number(votes || 0);
  return (s * v + 3 * 5) / (v + 5);
}
function computeBadges(createdAt, votes) {
  const out = [];
  const v = Number(votes || 0);
  const created = Date.parse(createdAt || "");
  if (Number.isFinite(created)) {
    const ageMs = Date.now() - created;
    if (ageMs >= 0 && ageMs < 7 * 24 * 60 * 60 * 1000) out.push("NOUVEAU");
  }
  if (v >= 10) out.push("CONFIRMÉ");
  return out;
}
function minimalSpotForUI(spot) {
  const score = Number(spot.score || 0), votes = Number(spot.votes || 0);
  return {
    id: spot.id, name: spot.name, lat: spot.lat, lon: spot.lon, desc: spot.desc || "",
    region: spot.region || "", country: spot.country || "", type: spot.type || "",
    dangerLevel: Number(spot.dangerLevel || 1), access: spot.access || "", ownerName: spot.ownerName || "",
    score, votes,
    scoreDisplayed: computeScoreDisplayed(score, votes),
    badges: computeBadges(spot.createdAt, votes),
    createdAt: spot.createdAt,
    hidden: spot.hidden === true,
  };
}

